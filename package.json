{
  "name": "tepa-monorepo",
  "private": true,
  "workspaces": [
    "packages/types",
    "packages/provider-core",
    "packages/tepa",
    "packages/tools",
    "packages/provider-anthropic",
    "packages/provider-openai",
    "packages/provider-gemini",
    "demos/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md,yaml,yml}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
