{
  "name": "@tepa/tools",
  "version": "0.1.0",
  "description": "Built-in tool definitions for the Tepa autonomous agent",
  "license": "MIT",
  "author": "Frandi <frandi.tech@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/frandi/tepa-ai.git",
    "directory": "packages/tools"
  },
  "homepage": "https://github.com/frandi/tepa-ai/tree/main/packages/tools#readme",
  "bugs": {
    "url": "https://github.com/frandi/tepa-ai/issues"
  },
  "keywords": [
    "tepa",
    "ai",
    "llm",
    "agent",
    "tools",
    "function-calling"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tepa/types": "^0.1.0",
    "glob": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
